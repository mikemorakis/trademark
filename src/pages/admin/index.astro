---
import { env } from "cloudflare:workers";

const db = env.DB;
const cookie = Astro.cookies.get('admin_session')?.value;
let loggedIn = cookie === 'authenticated';
let posts: any[] = [];
let categories: any[] = [];
let tags: any[] = [];
let error = '';
let success = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action')?.toString();

  if (action === 'login' && db) {
    const username = form.get('username')?.toString() || '';
    const password = form.get('password')?.toString() || '';
    const encoder = new TextEncoder();
    const hashBuffer = await crypto.subtle.digest('SHA-256', encoder.encode(password));
    const hashHex = Array.from(new Uint8Array(hashBuffer)).map(b => b.toString(16).padStart(2, '0')).join('');
    const user = await db.prepare('SELECT * FROM admin_users WHERE username = ? AND password_hash = ?').bind(username, hashHex).first();
    if (user) {
      Astro.cookies.set('admin_session', 'authenticated', { path: '/admin', httpOnly: true, secure: true, sameSite: 'strict', maxAge: 86400 });
      loggedIn = true;
    } else {
      error = 'Wrong username or password';
    }
  }

  if (action === 'logout') {
    Astro.cookies.delete('admin_session', { path: '/admin' });
    loggedIn = false;
  }

  if (action === 'add_category' && loggedIn && db) {
    const catName = form.get('new_category')?.toString() || '';
    if (catName) {
      const catSlug = catName.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-');
      try {
        await db.prepare('INSERT INTO categories (name, slug) VALUES (?, ?)').bind(catName, catSlug).run();
        success = 'Category added!';
      } catch(e: any) {
        error = e.message || 'Failed to add category';
      }
    }
  }

  if (action === 'create' && loggedIn && db) {
    const title = form.get('title')?.toString() || '';
    const slug = form.get('slug')?.toString() || '';
    const content = form.get('content')?.toString() || '';
    const date = form.get('date')?.toString() || new Date().toISOString().split('T')[0];
    const author = form.get('author')?.toString() || 'Giannis Psarakis';
    const categoryId = form.get('category_id')?.toString() || null;
    const image = form.get('image')?.toString() || null;
    try {
      const res = await db.prepare('INSERT INTO posts (title, slug, content, author, date, category_id, image, published) VALUES (?, ?, ?, ?, ?, ?, ?, 1) RETURNING id').bind(title, slug, content, author, date, categoryId, image).first();
      const postId = (res as any)?.id;
      const tagIds = form.getAll('tag_ids');
      if (postId && tagIds.length) {
        for (const tid of tagIds) {
          await db.prepare('INSERT OR IGNORE INTO post_tags (post_id, tag_id) VALUES (?, ?)').bind(postId, tid).run();
        }
      }
      success = 'Post created!';
    } catch(e: any) {
      error = e.message || 'Failed to create post';
    }
  }

  if (action === 'add_tag' && loggedIn && db) {
    const tagName = form.get('new_tag')?.toString() || '';
    if (tagName) {
      try {
        await db.prepare('INSERT INTO tags (name) VALUES (?)').bind(tagName).run();
        success = 'Tag added!';
      } catch(e: any) {
        error = e.message || 'Failed to add tag';
      }
    }
  }

  if (action === 'delete' && loggedIn && db) {
    const id = form.get('id')?.toString();
    if (id) {
      await db.prepare('DELETE FROM posts WHERE id = ?').bind(id).run();
      success = 'Post deleted';
    }
  }
}

if (loggedIn && db) {
  const result = await db.prepare('SELECT p.id, p.title, p.slug, p.date, p.published, c.name as category FROM posts p LEFT JOIN categories c ON p.category_id = c.id ORDER BY p.date DESC').all();
  posts = result.results || [];
  const catResult = await db.prepare('SELECT id, name, slug FROM categories ORDER BY name').all();
  categories = catResult.results || [];
  const tagResult = await db.prepare('SELECT id, name FROM tags ORDER BY name').all();
  tags = tagResult.results || [];
}
---

<html lang="el">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin | The Trademark Hoop</title>
  <style is:inline>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Verdana, sans-serif; background: #0f2d4a; color: #e5e7eb; }
    .admin-wrap { max-width: 900px; margin: 0 auto; padding: 24px; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 2px solid #fb6412; margin-bottom: 30px; }
    .admin-header h1 { font-size: 1.3rem; color: #fff; }
    .card { background: #1a3f5e; border-radius: 10px; padding: 28px; margin-bottom: 20px; box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
    label { display: block; font-size: 0.8rem; font-weight: 700; color: #9ca3af; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 1px; }
    input, textarea, select { width: 100%; padding: 10px 14px; border: 1px solid #2d5a7b; border-radius: 6px; font-family: Verdana, sans-serif; font-size: 0.9rem; margin-bottom: 16px; background: #0d2440; color: #e5e7eb; }
    textarea { min-height: 250px; resize: vertical; }
    input:focus, textarea:focus { outline: none; border-color: #fb6412; }
    input::placeholder { color: #6b7280; }
    .btn { display: inline-block; padding: 10px 24px; border: none; border-radius: 6px; font-family: Verdana, sans-serif; font-size: 0.8rem; font-weight: 700; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; }
    .btn-primary { background: #fb6412; color: #fff; }
    .btn-primary:hover { background: #e55a0e; }
    .btn-danger { background: #dc2626; color: #fff; font-size: 0.7rem; padding: 6px 14px; }
    .btn-danger:hover { background: #b91c1c; }
    .btn-outline { background: none; border: 1px solid #2d5a7b; color: #9ca3af; text-decoration: none; }
    .btn-outline:hover { border-color: #fb6412; color: #fb6412; }
    .alert { padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 0.85rem; }
    .alert-error { background: rgba(220,38,38,0.15); color: #fca5a5; border: 1px solid rgba(220,38,38,0.3); }
    .alert-success { background: rgba(22,163,74,0.15); color: #86efac; border: 1px solid rgba(22,163,74,0.3); }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1px; color: #9ca3af; padding: 10px 12px; border-bottom: 2px solid #2d5a7b; }
    td { padding: 12px; border-bottom: 1px solid #1a3f5e; font-size: 0.85rem; color: #d1d5db; }
    td a { color: #fb6412; text-decoration: none; }
    .login-wrap { max-width: 380px; margin: 80px auto; }
    .login-wrap h2 { text-align: center; margin-bottom: 24px; color: #fff; }
    .login-wrap img { display: block; margin: 0 auto 20px; height: 40px; }
    .post-actions { display: flex; gap: 8px; }
    .image-upload { border: 2px dashed #d1d5db; border-radius: 8px; padding: 24px; text-align: center; margin-bottom: 16px; cursor: pointer; transition: border-color 0.3s; }
    .image-upload:hover { border-color: #fb6412; }
    .image-upload img { max-height: 120px; margin-top: 10px; border-radius: 6px; }
    .image-upload input { display: none; }
    .image-preview { margin-top: 8px; }
    .ql-toolbar { border-radius: 6px 6px 0 0 !important; border-color: #2d5a7b !important; background: #fff !important; }
    .ql-container { border-radius: 0 0 6px 6px !important; border-color: #2d5a7b !important; min-height: 250px; font-family: Verdana, sans-serif; font-size: 0.9rem; background: #fff !important; color: #1f2937 !important; }
    .ql-editor { min-height: 250px; }
    .ql-container:focus-within { border-color: #fb6412 !important; }
  </style>
  <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
</head>
<body>
  {!loggedIn ? (
    <div class="login-wrap">
      <div class="card">
        <img src="/trademarkhoop-logo.png" alt="Logo" />
        <h2>Admin Login</h2>
        {error && <div class="alert alert-error">{error}</div>}
        <form method="POST">
          <input type="hidden" name="action" value="login" />
          <label>Username</label>
          <input type="text" name="username" required />
          <label>Password</label>
          <input type="password" name="password" required />
          <button type="submit" class="btn btn-primary" style="width:100%">Login</button>
        </form>
      </div>
    </div>
  ) : (
    <div class="admin-wrap">
      <div class="admin-header">
        <div style="display:flex;align-items:center;gap:12px;">
          <img src="/trademarkhoop-logo.png" alt="Logo" style="height:32px;" />
          <h1>Blog Admin</h1>
        </div>
        <div style="display:flex;gap:10px;">
          <a href="/" class="btn btn-outline">View Site</a>
          <form method="POST" style="display:inline;">
            <input type="hidden" name="action" value="logout" />
            <button type="submit" class="btn btn-outline">Logout</button>
          </form>
        </div>
      </div>

      {error && <div class="alert alert-error">{error}</div>}
      {success && <div class="alert alert-success">{success}</div>}

      <div class="card">
        <h2 style="margin-bottom: 20px; font-size: 1.1rem;">New Post</h2>
        <form method="POST">
          <input type="hidden" name="action" value="create" />
          <label>Title</label>
          <input type="text" name="title" id="postTitle" required oninput="document.getElementById('postSlug').value=this.value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'')" />
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
            <div>
              <label>Slug (URL) <span style="font-weight:400;text-transform:none;font-size:0.7rem;color:#6b7280;">auto-generated</span></label>
              <input type="text" name="slug" id="postSlug" required placeholder="auto-generated" />
            </div>
            <div>
              <label>Date</label>
              <input type="date" name="date" value={new Date().toISOString().split('T')[0]} />
            </div>
            <div>
              <label>Author</label>
              <input type="text" name="author" value="Giannis Psarakis" />
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:4px;">
            <div>
              <label>Category</label>
              <select name="category_id" style="width:100%;padding:10px 14px;border:1px solid #2d5a7b;border-radius:6px;font-family:Verdana,sans-serif;font-size:0.9rem;margin-bottom:16px;background:#0d2440;color:#e5e7eb;">
                <option value="">-- No category --</option>
                {categories.map((cat: any) => (
                  <option value={cat.id}>{cat.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label>Add New Category</label>
              <div style="display:flex;gap:8px;">
                <input type="text" id="newCatInput" placeholder="New category name" style="flex:1;margin-bottom:0;" />
                <button type="button" class="btn btn-outline" style="white-space:nowrap;padding:10px 16px;" onclick="
                  const inp = document.getElementById('newCatInput');
                  if (!inp.value) return;
                  const fd = new FormData();
                  fd.append('action', 'add_category');
                  fd.append('new_category', inp.value);
                  fetch('/admin/', { method: 'POST', body: fd }).then(() => location.reload());
                ">+ Add</button>
              </div>
            </div>
          </div>
          <label>Tags</label>
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
            {tags.map((tag: any) => (
              <label style="display:flex;align-items:center;gap:4px;padding:4px 10px;background:#0d2440;border:1px solid #2d5a7b;border-radius:16px;font-size:0.75rem;cursor:pointer;">
                <input type="checkbox" name="tag_ids" value={tag.id} style="width:14px;height:14px;accent-color:#fb6412;" />
                {tag.name}
              </label>
            ))}
          </div>
          <div style="display:flex;gap:8px;margin-bottom:16px;">
            <input type="text" id="newTagInput" placeholder="New tag" style="flex:1;margin-bottom:0;" />
            <button type="button" class="btn btn-outline" style="white-space:nowrap;padding:10px 16px;" onclick="
              const inp = document.getElementById('newTagInput');
              if (!inp.value) return;
              const fd = new FormData();
              fd.append('action', 'add_tag');
              fd.append('new_tag', inp.value);
              fetch('/admin/', { method: 'POST', body: fd }).then(() => location.reload());
            ">+ Tag</button>
          </div>
          <label>Featured Image</label>
          <div class="image-upload" id="imageUploadArea" onclick="document.getElementById('imageFile').click()">
            <input type="file" id="imageFile" accept="image/*" />
            <input type="hidden" name="image" id="imageUrl" />
            <div id="imagePreview">
              <p style="color:#9ca3af;font-size:0.85rem;">Click to upload image</p>
            </div>
          </div>

          <label>Content</label>
          <div id="editor"></div>
          <textarea name="content" id="contentField" required style="display:none;"></textarea>
          <div style="margin-top:16px;">
            <button type="submit" class="btn btn-primary" onclick="document.getElementById('contentField').value=quill.root.innerHTML;">Publish Post</button>
          </div>
        </form>
      </div>

      <div class="card">
        <h2 style="margin-bottom: 20px; font-size: 1.1rem;">All Posts ({posts.length})</h2>
        <table>
          <thead>
            <tr><th>Title</th><th>Category</th><th>Date</th><th>Actions</th></tr>
          </thead>
          <tbody>
            {posts.map((post: any) => (
              <tr>
                <td><a href={`/blog/${post.slug}`} target="_blank">{post.title}</a></td>
                <td><span style={`font-size:0.72rem;padding:3px 8px;border-radius:10px;background:${post.category ? 'rgba(251,100,18,0.15)' : 'transparent'};color:${post.category ? '#fb6412' : '#6b7280'};`}>{post.category || '—'}</span></td>
                <td>{post.date}</td>
                <td>
                  <div class="post-actions">
                    <a href={`/admin/edit/${post.id}`} class="btn btn-outline" style="font-size:0.7rem;padding:6px 12px;">Edit</a>
                    <form method="POST" onsubmit="return confirm('Delete this post?')">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={post.id} />
                      <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <script is:inline src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script is:inline>
      document.getElementById('imageFile').addEventListener('change', async function(e) {
        var file = e.target.files[0];
        if (!file) return;
        var preview = document.getElementById('imagePreview');
        preview.innerHTML = '<p style="color:#fb6412;">Uploading...</p>';
        var fd = new FormData();
        fd.append('file', file);
        try {
          var res = await fetch('/api/upload', { method: 'POST', body: fd });
          var data = await res.json();
          if (data.url) {
            document.getElementById('imageUrl').value = data.url;
            preview.innerHTML = '<img src="' + data.url + '" style="max-height:120px;border-radius:6px;" /><p style="font-size:0.75rem;color:#16a34a;margin-top:8px;">Uploaded!</p>';
          } else {
            preview.innerHTML = '<p style="color:#dc2626;">Error: ' + (data.error || 'Upload failed') + '</p>';
          }
        } catch(err) {
          preview.innerHTML = '<p style="color:#dc2626;">Upload failed</p>';
        }
      });
      var quill = new Quill('#editor', {
        theme: 'snow',
        modules: {
          toolbar: [
            [{ 'header': [2, 3, 4, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['blockquote', 'link', 'image'],
            [{ 'align': [] }],
            ['clean']
          ]
        },
        placeholder: 'Write your post content here...'
      });
    </script>
  )}
</body>
</html>
