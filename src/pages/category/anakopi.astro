---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchivePage from '../../components/ArchivePage.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
let posts: any[] = [];
if (db) {
  const result = await db.prepare(`
    SELECT DISTINCT p.id, p.title, p.slug, p.date, p.author, p.image, p.content
    FROM posts p LEFT JOIN post_tags pt ON p.id = pt.post_id LEFT JOIN tags t ON pt.tag_id = t.id
    WHERE p.published = 1 AND t.name IN ('ΑΝΑΚΟΠΗ', 'ΚΙΝΔΥΝΟΣ ΣΥΓΧΥΣΗΣ', 'ΜΟΡΦΕΣ ΠΡΟΣΒΟΛΗΣ', 'ΠΡΟΣΒΟΛΗ ΣΗΜΑΤΟΣ', 'ΣΗΜΑΤΑ ΦΗΜΗΣ', 'ΑΠΟΜΙΜΗΣΗ')
    ORDER BY p.date DESC
  `).all();
  posts = result.results || [];
}
---

<BaseLayout title="Ανακοπή Εμπορικού Σήματος" description="Ανακοπή, ένσταση, κίνδυνος σύγχυσης και προσβολή εμπορικού σήματος">
  <section class="news-section">
    <div class="container">
      <ArchivePage title="Ανακοπή Εμπορικού Σήματος" description="Ανακοπή, ένσταση και προσβολή σήματος" posts={posts} />
    </div>
  </section>
</BaseLayout>
