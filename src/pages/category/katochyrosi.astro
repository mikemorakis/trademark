---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
let posts: any[] = [];
if (db) {
  const result = await db.prepare(`
    SELECT DISTINCT p.id, p.title, p.slug, p.date, p.author, p.image, p.content
    FROM posts p
    LEFT JOIN post_tags pt ON p.id = pt.post_id
    LEFT JOIN tags t ON pt.tag_id = t.id
    WHERE p.published = 1 AND t.name IN ('ΚΑΤΟΧΥΡΩΣΗ', 'ΚΑΤΑΧΩΡΙΣΗ', 'ΚΑΤΑΘΕΣΗ', 'ΕΛΕΓΧΟΣ', 'ΕΜΠΟΡΙΚΑ ΣΗΜΑΤΑ', 'ΔΙΑΔΙΚΑΣΙΑ', 'DOMAIN NAMES')
    ORDER BY p.date DESC
  `).all();
  posts = result.results || [];
}
---

<BaseLayout title="Κατοχύρωση Εμπορικού Σήματος" description="Άρθρα και αναλύσεις για την κατοχύρωση εμπορικού σήματος σε Ελλάδα, ΕΕ και διεθνώς">
  <main class="container" style="padding-top: 40px; padding-bottom: 60px;">
    <h1 style="margin-bottom: 8px;">Κατοχύρωση Εμπορικού Σήματος</h1>
    <p style="color: var(--text-gray); margin-bottom: 40px;">Άρθρα και αναλύσεις για την κατοχύρωση εμπορικού σήματος σε Ελλάδα, ΕΕ και διεθνώς</p>
    <div class="archive-grid">
      {posts.map((post: any) => (
        <PostCard title={post.title} slug={post.slug} date={post.date} author={post.author} image={post.image} content={post.content} />
      ))}
    </div>
  </main>
</BaseLayout>
