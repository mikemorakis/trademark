---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { env } from "cloudflare:workers";

const { slug } = Astro.params;
const db = env.DB;
let post: any = null;

if (db && slug) {
  const result = await db.prepare('SELECT * FROM posts WHERE slug = ? AND published = 1').bind(slug).first();
  post = result;
}

if (!post) {
  return Astro.redirect('/blog/');
}
---

<BaseLayout title={post.title} description={post.description || post.title}>
  <main class="container" style="padding-top: 40px; padding-bottom: 60px;">
    <article class="single-post">
      <h1>{post.title}</h1>
      <div class="post-meta">
        <span>{post.date}</span>
        <span>{post.author}</span>
      </div>
      <div class="post-content" set:html={post.content.replace(/\n/g, '<br/>')} />
      <div style="margin-top: 40px;">
        <a href="/blog/" style="color: var(--orange); font-weight: 700;">&larr; Όλα τα άρθρα</a>
      </div>
    </article>
  </main>
</BaseLayout>
