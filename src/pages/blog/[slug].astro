---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { env } from "cloudflare:workers";

const { slug } = Astro.params;
const db = env.DB;
let post: any = null;
let recentPosts: any[] = [];
let tags: any[] = [];

if (db && slug) {
  post = await db.prepare('SELECT * FROM posts WHERE slug = ? AND published = 1').bind(slug).first();
  const recent = await db.prepare('SELECT title, slug, date FROM posts WHERE published = 1 AND slug != ? ORDER BY date DESC LIMIT 5').bind(slug).all();
  recentPosts = recent.results || [];
  const tagResult = await db.prepare('SELECT t.name FROM tags t JOIN post_tags pt ON t.id = pt.tag_id JOIN posts p ON pt.post_id = p.id WHERE p.slug = ?').bind(slug).all();
  tags = tagResult.results || [];
}

if (!post) {
  return Astro.redirect('/blog/');
}

// Sanitize content - close unclosed tags to prevent DOM bleed
let safeContent = (post.content || '').replace(/<img([^>]*)(?<!\/)>/gi, '<img$1 />');
// Remove any unclosed div/span/p/a/table tags at the end
const openTags: string[] = [];
safeContent.replace(/<(p|div|span|table|tr|td|th|ul|ol|li|blockquote|strong|em|b|i|a|h[1-6])\b[^>]*>/gi, (_m: string, tag: string) => { openTags.push(tag.toLowerCase()); return ''; });
safeContent.replace(/<\/(p|div|span|table|tr|td|th|ul|ol|li|blockquote|strong|em|b|i|a|h[1-6])>/gi, (_m: string, tag: string) => { const idx = openTags.lastIndexOf(tag.toLowerCase()); if (idx !== -1) openTags.splice(idx, 1); return ''; });
for (let i = openTags.length - 1; i >= 0; i--) safeContent += `</${openTags[i]}>`;
---

<BaseLayout title={post.title} description={post.description || post.title}>
  <div class="container" style="padding-top: 40px; padding-bottom: 60px;">
    <div class="post-layout">
      <!-- Article -->
      <article class="single-post">
        <h1>{post.title}</h1>
        <div class="post-meta">
          <span>{post.date} — του {post.author}{post.colab && <Fragment> σε συνεργασία με {post.colab_url ? <a href={post.colab_url} target="_blank" rel="noopener" style="color: var(--orange); font-weight: 600;">{post.colab}</a> : post.colab}</Fragment>}</span>
        </div>
        {post.image && <img src={post.image} alt={post.title} style="width:100%;border-radius:10px;margin-bottom:24px;" />}
        <div class="post-content" set:html={safeContent}></div>
        {tags.length > 0 && (
          <div class="post-tags-list">
            {tags.map((t: any) => <a href={`/tag/${encodeURIComponent(t.name)}`} class="post-tag-pill">{t.name}</a>)}
          </div>
        )}
        <div style="margin-top: 40px;">
          <a href="/blog/" style="color: var(--orange); font-weight: 700;">&larr; Όλα τα άρθρα</a>
        </div>
      </article>

      <!-- Sidebar -->
      <aside class="post-sidebar">
        <!-- B2B Lawyer Banner -->
        <div class="ps-widget ps-banner-b2b">
          <span class="ps-banner-label">B2B</span>
          <h4>Δικηγόρος Εμπορικών Σημάτων</h4>
          <p>Εξειδικευμένες νομικές υπηρεσίες για επιχειρήσεις. Κατοχύρωση, ανακοπή & προστασία σημάτων.</p>
          <a href="/p/blog-page_8.html" class="ps-banner-btn">Επικοινωνήστε μαζί μας</a>
        </div>

        <!-- Become Partner Banner -->
        <div class="ps-widget ps-banner-partner">
          <span class="ps-banner-label">Συνεργασία</span>
          <h4>Γίνε Συνεργάτης</h4>
          <p>Αρθρογραφείς στον χώρο του IP; Δημοσίευσε στο thetrademarkhoop.com</p>
          <a href="/p/blog-page_8.html" class="ps-banner-btn-outline">Στείλε μας το άρθρο σου</a>
        </div>

        <!-- Recent Posts -->
        <div class="ps-widget">
          <h4>Πρόσφατα Άρθρα</h4>
          {recentPosts.map((p: any) => (
            <a href={`/blog/${p.slug}`} class="ps-recent">
              <span class="ps-recent-date">{p.date}</span>
              <span class="ps-recent-title">{p.title}</span>
            </a>
          ))}
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>
