---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
let posts: any[] = [];
if (db) {
  const result = await db.prepare('SELECT id, title, slug, date, author, image, content FROM posts WHERE published = 1 ORDER BY date DESC').all();
  posts = result.results || [];
}
---

<BaseLayout title="Blog" description="Αρθρογραφία και αναλύσεις σε θέματα εμπορικών σημάτων">
  <main class="container" style="padding-top: 40px; padding-bottom: 60px;">
    <h1 style="margin-bottom: 8px;">Blog</h1>
    <p style="color: var(--text-gray); margin-bottom: 40px;">Αρθρογραφία και αναλύσεις σε θέματα εμπορικών σημάτων</p>
    <div class="archive-grid">
      {posts.map((post: any) => (
        <PostCard title={post.title} slug={post.slug} date={post.date} author={post.author} image={post.image} content={post.content} />
      ))}
    </div>
  </main>
</BaseLayout>
