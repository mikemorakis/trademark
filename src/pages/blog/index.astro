---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchivePage from '../../components/ArchivePage.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
let posts: any[] = [];
if (db) {
  const result = await db.prepare('SELECT id, title, slug, date, author, image, content FROM posts WHERE published = 1 ORDER BY date DESC').all();
  posts = result.results || [];
}
---

<BaseLayout title="Blog" description="Αρθρογραφία και αναλύσεις σε θέματα εμπορικών σημάτων">
  <section class="news-section">
    <div class="container">
      <ArchivePage title="Όλα τα Άρθρα" description="Αρθρογραφία και αναλύσεις σε θέματα εμπορικών σημάτων" posts={posts} />
    </div>
  </section>
</BaseLayout>
