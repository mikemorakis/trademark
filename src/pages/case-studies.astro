---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArchivePage from '../components/ArchivePage.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
let posts: any[] = [];
if (db) {
  const result = await db.prepare(`
    SELECT DISTINCT p.id, p.title, p.slug, p.date, p.author, p.image, p.content
    FROM posts p JOIN post_tags pt ON p.id = pt.post_id JOIN tags t ON pt.tag_id = t.id
    WHERE p.published = 1 AND t.name IN ('LA LIGA', 'NETFLIX', 'TURKAEGEAN', 'MILAN', 'JUVENTUS')
    ORDER BY p.date DESC
  `).all();
  posts = result.results || [];
}
---

<BaseLayout title="Case Studies" description="Ανάλυση υποθέσεων εμπορικών σημάτων - Netflix, Juventus, Milan AC, Turkaegean">
  <section class="news-section">
    <div class="container">
      <ArchivePage title="Case Studies" description="Netflix, Juventus, Milan AC, Turkaegean & more" posts={posts} />
    </div>
  </section>
</BaseLayout>
