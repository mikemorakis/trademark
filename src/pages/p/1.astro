<BaseLayout title="TM Stories+" description="Ιστορίες εμπορικών σημάτων - The Trademark Hoop">
  <div class="main-content">
    <div class="content-area">
      <div class="page-content">
        <h1>TM Stories+</h1>
        <div class="stories-grid">
          {stories.map(story => (
            <div class="story-card">
              <div class="story-body">
                <h4><a href={story.url}>{story.title}</a></h4>
                {story.source && <span class="story-source">{story.source}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <Sidebar />
  </div>
</BaseLayout>
