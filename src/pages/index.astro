---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: 'Με συμφέρει η κατοχύρωση εμπορικού σήματος;',
    answer: 'Η κατοχύρωση εμπορικού σήματος αποτελεί μια ιδιαίτερα συμφέρουσα επιλογή για κάθε επιχείρηση. Σύμφωνα με έρευνες, επιχειρήσεις που επενδύουν σε δικαιώματα διανοητικής ιδιοκτησίας παρουσιάζουν αυξημένα έσοδα ανά υπάλληλο κατά 55%. Η Ελλάδα προσφέρει τα χαμηλότερα τέλη καταχώρισης μεταξύ συγκρίσιμων ευρωπαϊκών χωρών, στα 100 ευρώ ανά κλάση.',
  },
  {
    question: 'Τι είναι το εμπορικό σήμα και τι μπορώ να κατοχυρώσω ως τέτοιο;',
    answer: 'Σύμφωνα με τον νόμο 4679/2020, εμπορικό σήμα μπορεί να αποτελείται από λέξεις, ονόματα, σχέδια, γράμματα, αριθμούς, χρώματα, σχήμα προϊόντος ή συσκευασίας, ή ήχους, εφόσον μπορούν να διακρίνουν τα προϊόντα ή τις υπηρεσίες μιας επιχείρησης από εκείνα άλλων.',
  },
  {
    question: 'Προστατεύομαι για πάντα; Σε ποιες περιοχές;',
    answer: 'Η προστασία διαρκεί 10 έτη από την ημερομηνία κατάθεσης, με δυνατότητα ανανέωσης επ\' αόριστον. Οι επιλογές καταχώρισης περιλαμβάνουν: εθνικό σήμα (προστασία στην Ελλάδα), σήμα ΕΕ (προστασία σε όλα τα κράτη-μέλη) ή διεθνή καταχώριση (προστασία σε συγκεκριμένες χώρες).',
  },
  {
    question: 'Γιατί χρειάζομαι τη βοήθεια ενός ειδικού στα εμπορικά σήματα πριν την καταχώριση;',
    answer: 'Η καταχώριση σήματος χωρίς προηγούμενη νομική μελέτη μπορεί να αποτελέσει "παγίδα πρώτης κατηγορίας" για τον σηματούχο. Τρίτοι μπορούν να αμφισβητήσουν το σήμα με αιτήσεις ακύρωσης, αγωγές ή ποινικές διώξεις. Η εξειδικευμένη συμβουλή εντοπίζει κινδύνους και αυξάνει σημαντικά τις πιθανότητες επιτυχούς άμυνας.',
  },
  {
    question: 'Έχω εμπορικό σήμα. Το καταχώρισα στο Μητρώο Σημάτων. Είμαι ασφαλής;',
    answer: 'Όχι. Η καταχώριση εμπορικού σήματος δεν εγγυάται ότι τρίτοι δεν θα ζητήσουν ακύρωση, αποζημίωση ή ποινική δίωξη. Η ποιότητα της προεργασίας πριν την καταχώριση είναι κρίσιμη για τη μακροχρόνια ασφάλεια του σήματος.',
  },
  {
    question: 'Κάποιος τρίτος χρησιμοποιεί μια ένδειξη ίδια ή παρόμοια με το σήμα μου. Τι μπορώ να κάνω;',
    answer: 'Υπάρχουν πολλαπλές δυνατότητες: εξώδικη όχληση (πιο οικονομική αφετηρία), ασφαλιστικά μέτρα (αποτελεσματικά εντός 2-3 ημερών), κύρια αγωγή (αξίωση παύσης, καταστροφής προϊόντων, αποζημίωσης), αίτηση ακύρωσης, καθώς και ποινική δίωξη.',
  },
  {
    question: 'Αμέλησα και δεν καταχώρισα εμπορικό σήμα. Αυτό σημαίνει ότι δεν προστατεύομαι;',
    answer: 'Η καταχώριση είναι συνιστώμενη πριν την εμπορική χρήση αλλά δεν αποτελεί τον μοναδικό μηχανισμό προστασίας. Μη καταχωρισμένα δικαιώματα προκύπτουν από συνεχή εμπορική χρήση. Ωστόσο, η καταχώριση παρέχει δικονομικά πλεονεκτήματα και πρόσβαση σε ειδικές ποινικές διατάξεις.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const stories = [
  { title: 'Μια υπόθεση ελληνικών συμφερόντων: η κατοχύρωση εμπορικού σήματος και το συχνότερο λάθος κατά την καταχώριση', url: '/2022/01/kataxorisi-simatos-elegxos.html', source: 'Naftemporiki' },
  { title: 'Αλλαγή δεδομένων από το Γενικό Δικαστήριο της ΕΕ: Χρήσιμα συμπεράσματα για τον ΟΒΙ', url: '/2021/10/OBI-SIMATA-EUIPO.html', source: 'OBI / EUIPO' },
  { title: 'Οι σύγχρονες μελέτες για την κατοχύρωση εμπορικού σήματος', url: '/2022/06/katoxirosi-simatos-dhlwsh.html', source: 'HuffingtonPost' },
  { title: 'Turkaegean: Ο Ατατούρκ και 11 σκέψεις', url: '/2022/07/emporiko-sima-onoma-turkaegean-euipo-katoxurosi.html', source: 'Analysis' },
  { title: 'Το εμπορικό σήμα ως περιουσιακό στοιχείο: αριθμοί, προστασία και δύο προτάσεις', url: '/2021/11/emporiko-sima-dikigoros-kataxorisi-katoxurosi.html', source: 'Startup.gr' },
  { title: 'Milan AC: Ένας αγώνας που δεν κερδήθηκε και ένα δίδαγμα', url: '/2022/01/emporiko-sima-EE-EUIPO.html', source: 'EUIPO Case' },
  { title: 'Όταν το Netflix επιχείρησε να καταχωρίσει το ηχητικό του ως σήμα ΕΕ', url: '/2022/04/trademark-netflix-euipo.html', source: 'TheTotalBusiness' },
  { title: 'Η κατοχύρωση του νέου σήματος της Juventus', url: '/2022/08/trademark-simata-dikigoros-juv.html', source: 'Capital.gr' },
];

const academicPubs = [
  { title: 'European Intellectual Property Review', publisher: 'Sweet & Maxwell', url: '/2024/01/european-intellectual-property-review.html', initials: 'EIPR' },
  { title: 'Kluwer Trademark Blog', publisher: 'Wolters Kluwer N.V.', url: '/2024/01/kluwer-trademark-blog-wolters-kluwer-nv.html', initials: 'KTB' },
  { title: 'Journal of Intellectual Property Law & Practice', publisher: 'Oxford University Press', url: '/2023/05/journal-of-intellectual-property-law.html', initials: 'JIPLP' },
  { title: 'Ο κίνδυνος σύγχυσης στο δίκαιο του σήματος', publisher: 'Νομική Βιβλιοθήκη (Monograph)', url: '/2022/09/dikaio-simatwn.html', initials: 'NB' },
  { title: 'Δίκαιο Τεχνολογίας & Επικοινωνίας (ΔΙΤΕ)', publisher: 'Νομική Βιβλιοθήκη', url: '/2024/02/adwords-google-trademark.html', initials: 'DITE' },
  { title: 'ΣΥΝΗΓΟΡΟΣ', publisher: 'Νομική Βιβλιοθήκη', url: '/2023/04/blog-post.html', initials: 'SYN' },
];

const clients = [
  'Client 1', 'Client 2', 'Client 3',
  'Client 4', 'Client 5', 'Client 6',
  'Client 7', 'Client 8', 'Client 9',
];
---

<BaseLayout title="Κατοχύρωση Εμπορικού Σήματος" description="Κατοχύρωση εμπορικού σήματος - Δικηγόρος εμπορικών σημάτων | The Trademark Hoop - Psarakis | Kephalas Law Firm. Advice. Registration. Litigation." transparentHeader={true}>
  <!-- FAQ Schema for SEO -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- SECTION 1: Hero -->
  <section class="hero-home">
    <div class="hero-content">
      <p class="hero-eyebrow">Δικηγόρος Εμπορικών Σημάτων</p>
      <h1 class="hero-h1">Κατοχύρωση, Ένσταση & Ανάκληση<br/>Εμπορικού Σήματος</h1>
      <p class="hero-sub">Εξειδικευμένες νομικές υπηρεσίες εμπορικού σήματος: Κατοχύρωση, ανακοπή (opposition) και διαγραφή (cancellation) σημάτων ανταγωνιστών, αντιδικία παύσης χρήσης τρίτων, εξωδική προστασία σε Ελλάδα και Ευρωπαϊκή Ένωση.</p>
      <form class="hero-email-form" action="https://formsubmit.co/info@thetrademarkhoop.com" method="POST">
        <input type="hidden" name="_subject" value="Νέο lead από hero - thetrademarkhoop.com" />
        <input type="hidden" name="_next" value="https://www.thetrademarkhoop.com/" />
        <input type="text" name="_honey" style="display:none" />
        <input type="email" name="email" placeholder="Συμπληρώστε το mail σας και θα επικοινωνήσουμε μαζί σας εντός 24ώρου" required />
      </form>
      <div class="hero-buttons">
        <a href="/p/blog-page_8.html" class="btn-hero-primary"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Κατοχύρωση Σήματος</a>
        <a href="/p/blog-page_8.html" class="btn-hero-outline"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>Διαχείριση Ενστάσεων</a>
      </div>
      <ul class="hero-trust">
        <li><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.3 4.3l-6.8 6.8-3.8-3.8 1.1-1.1 2.7 2.7 5.7-5.7 1.1 1.1z" fill="currentColor"/></svg>Εξειδίκευση σε εμπορικά σήματα</li>
        <li><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.3 4.3l-6.8 6.8-3.8-3.8 1.1-1.1 2.7 2.7 5.7-5.7 1.1 1.1z" fill="currentColor"/></svg>Ελλάδα, ΕΕ & Διεθνής Προστασία</li>
      </ul>
    </div>
  </section>

  <!-- Tagline Banner -->
  <section class="tagline-banner">
    <div class="container">
      <div class="tagline-content">
        <div class="tagline-text">
          <span>Hoop it.</span>
          <span>Don't get hooped.</span>
          <span>Legally.</span>
        </div>
        <p class="tagline-services">[ Advice.Registration.Litigation ]</p>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Trusting the Experts -->
  <section class="section-services" id="services">
    <div class="container">
      <div class="services-header">
        <span class="section-label">The Trademark Hoop:</span>
        <h2>Trusting the Experts</h2>
      </div>
      <div class="services-grid">
        <div class="services-intro">
          <p>Το Trademark Hoop είναι το trademark hub της Δικηγορικής Εταιρείας Ψαράκης|Κεφαλάς. Στο Trademark Hoop ασχολούμαστε αποκλειστικά με υποθέσεις εμπορικού σήματος.</p>
          <p>Ενδεικτικά, οι υπηρεσίες οι οποίες παρέχουμε είναι οι εξής:</p>
          <ul class="services-list">
            <li><strong>Κατοχύρωση Εμπορικού Σήματος</strong>Κατάθεση, κατόπιν πλήρους νομικού προελέγχου, δηλώσεων εμπορικών σημάτων σε εθνικό, ενωσιακό (εμπορικό σήμα της Ε.Ε.) και διεθνές επίπεδο (π.χ. ΗΠΑ, Ηνωμένο Βασίλειο, Κίνα κτλ).</li>
            <li><strong>Σχεδιασμός & Προσαρμογή</strong>Εφόσον είναι αναγκαίο, κατάλληλη προσαρμογή της ένδειξης από επαγγελματίες γραφίστες με τους οποίους διατηρούμε σταθερή συνεργασία, ανά την Ελλάδα, ούτως ώστε να επιτυγχάνεται το βέλτιστο νομικό και εμπορικό αποτέλεσμα.</li>
            <li><strong>Εξωδικαστική Επίλυση</strong>Εξωδικαστική αντιμετώπιση υποθέσεων που αφορούν σε προσβολή εμπορικού σήματος.</li>
            <li><strong>Δικαστική Εκπροσώπηση</strong>Ανάληψη υποθέσεων που αφορούν σε δικαστικές διενέξεις στο πεδίο των εμπορικών σημάτων, σε αστικό, σε διοικητικό και σε ποινικό επίπεδο.</li>
            <li><strong>Νομικές Γνωμοδοτήσεις</strong>Σύνταξη γνωμοδοτήσεων σε σύνθετα ζητήματα του δικαίου των εμπορικών σημάτων, για δικαστική ή ιδία χρήση.</li>
          </ul>
        </div>
        <div class="services-summary">
          <p>Απόλυτη εξειδίκευση στα ζητήματα εμπορικών σημάτων, συνεχής παρακολούθηση των εξελίξεων, ενεργή παρουσία στην ακαδημαϊκή και επιστημονική κοινότητα. Όλα αυτά συγκεντρωμένα σε υπηρεσίες προσαρμοσμένες στις ιδιαίτερες ανάγκες της κάθε περίπτωσης.</p>
          <a href="/p/we-do.html" class="btn-primary">Μάθετε περισσότερα</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Academic Contributions -->
  <section class="section-academic" id="academic">
    <div class="container">
      <h2 class="section-title">Academic Contributions</h2>
      <p class="section-subtitle">Δημοσιεύσεις του Γιάννη Ψαράκη, ιδρυτή της Trademark Hoop, σε διεθνή και ελληνικά νομικά περιοδικά</p>
      <div class="academic-grid">
        {academicPubs.map(pub => (
          <a href={pub.url} class="academic-item">
            <span class="pub-logo">{pub.initials}</span>
            <div>
              <h3>{pub.title}</h3>
              <span class="publisher">{pub.publisher}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="center-cta">
        <a href="/p/1.html" class="btn-outline btn-outline-light">Δείτε όλα τα Academic Contributions</a>
      </div>
    </div>
  </section>

  <!-- SECTION 4: TM Stories -->
  <section class="section-stories" id="stories">
    <div class="container">
      <h2 class="section-title">TM Stories</h2>
      <p class="section-subtitle">Αρθρογραφία και αναλύσεις σε θέματα εμπορικών σημάτων</p>
      <div class="stories-grid-home">
        {stories.map(story => (
          <a href={story.url} class="story-item">
            <div class="story-header">
              <span class="story-logo">{story.source.charAt(0)}</span>
              <span class="story-source-badge">{story.source}</span>
            </div>
            <h3>{story.title}</h3>
          </a>
        ))}
      </div>
      <div class="center-cta">
        <a href="/p/1.html" class="btn-outline">Δείτε όλα τα TM Stories</a>
      </div>
    </div>
  </section>

  <!-- SECTION: Clients -->
  <section class="section-clients" id="clients">
    <div class="container">
      <h2 class="section-title">Εταιρίες που μας εμπιστεύτηκαν</h2>
      <p class="section-subtitle">Επιχειρήσεις και οργανισμοί που επέλεξαν το Trademark Hoop για την προστασία των σημάτων τους</p>
      <div class="clients-grid">
        {clients.map((client, i) => (
          <div class="client-item">
            <span class="client-placeholder">{client}</span>
          </div>
        ))}
      </div>
      <div class="center-cta">
        <a href="/p/who.html" class="btn-outline">Όλες οι εταιρείες</a>
      </div>
    </div>
  </section>

  <!-- SECTION 5: FAQ with Schema -->
  <section class="section-faq" id="faq">
    <div class="container">
      <h2 class="section-title">Συχνές Ερωτήσεις (FAQ)</h2>
      <div class="faq-list">
        {faqItems.map((item, i) => (
          <details class="faq-accordion" open={i === 0}>
            <summary>{item.question}</summary>
            <div class="faq-answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
      <div class="center-cta">
        <a href="/p/trademark-hoop.html" class="btn-outline">Δείτε όλες τις ερωτήσεις</a>
      </div>
    </div>
  </section>

  <!-- SECTION 6: Contact -->
  <section class="section-contact" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Επικοινωνήστε μαζί μας</h2>
          <p class="contact-desc">Συμπληρώστε τη φόρμα ή επικοινωνήστε απευθείας μαζί μας.</p>
          <div class="contact-details">
            <div class="contact-detail">
              <strong>Διεύθυνση</strong>
              <span>Λυκαβηττού 2, Κολωνάκι</span>
            </div>
            <div class="contact-detail">
              <strong>Τηλέφωνο</strong>
              <span>213 046 4985</span>
            </div>
            <div class="contact-detail">
              <strong>Κινητό</strong>
              <span>693 27 87 671</span>
            </div>
            <div class="contact-detail">
              <strong>Email</strong>
              <a href="mailto:info@thetrademarkhoop.com">info@thetrademarkhoop.com</a>
            </div>
          </div>
        </div>
        <form class="contact-form-home" action="https://formsubmit.co/info@thetrademarkhoop.com" method="POST" id="contactForm">
          <input type="hidden" name="_captcha" value="true" />
          <input type="hidden" name="_subject" value="Νέο μήνυμα από thetrademarkhoop.com" />
          <input type="hidden" name="_next" value="https://www.thetrademarkhoop.com/" />
          <input type="text" name="_honey" style="display:none" />
          <input type="text" name="name" placeholder="Όνομα" required />
          <input type="email" name="email" placeholder="Email" required />
          <input type="tel" name="phone" placeholder="Τηλέφωνο (προαιρετικό)" />
          <textarea name="message" placeholder="Μήνυμα" required></textarea>
          <label class="form-consent">
            <input type="checkbox" id="consentCheck" required />
            <span>Αποδέχομαι τους <a href="/p/trademark-hoop_26.html" target="_blank">Όρους Χρήσης</a> και την <a href="/p/trademark-hoop_26.html" target="_blank">Πολιτική Απορρήτου</a>. Συναινώ στη συλλογή και επεξεργασία των δεδομένων μου σύμφωνα με τον GDPR για τον σκοπό της επικοινωνίας.</span>
          </label>
          <button type="submit">Αποστολή</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
