---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
let allPosts: any[] = [];
let featuredPost: any = null;
let categories: any[] = [];
let tags: any[] = [];

if (db) {
  const result = await db.prepare('SELECT id, title, slug, date, author, image, content FROM posts WHERE published = 1 ORDER BY date DESC').all();
  allPosts = result.results || [];
  featuredPost = allPosts[0] || null;
  const catResult = await db.prepare('SELECT id, name, slug FROM categories ORDER BY name').all();
  categories = catResult.results || [];
  const tagResult = await db.prepare('SELECT t.id, t.name, COUNT(pt.post_id) as count FROM tags t LEFT JOIN post_tags pt ON t.id = pt.tag_id GROUP BY t.id ORDER BY count DESC LIMIT 20').all();
  tags = tagResult.results || [];
}

const feedPosts = allPosts.slice(1, 11);
const excerpt = (content: string, len = 160) => {
  if (!content) return '';
  const text = content.replace(/<[^>]*>?/g, '').replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/\s+/g, ' ').trim();
  return text.length > len ? text.substring(0, len) + '...' : text;
};

const faqItems = [
  { question: 'Με συμφέρει η κατοχύρωση εμπορικού σήματος;', answer: 'Η κατοχύρωση εμπορικού σήματος αποτελεί μια ιδιαίτερα συμφέρουσα επιλογή για κάθε επιχείρηση. Σύμφωνα με έρευνες, επιχειρήσεις που επενδύουν σε δικαιώματα διανοητικής ιδιοκτησίας παρουσιάζουν αυξημένα έσοδα ανά υπάλληλο κατά 55%. Η Ελλάδα προσφέρει τα χαμηλότερα τέλη καταχώρισης μεταξύ συγκρίσιμων ευρωπαϊκών χωρών, στα 100 ευρώ ανά κλάση.' },
  { question: 'Τι είναι το εμπορικό σήμα και τι μπορώ να κατοχυρώσω;', answer: 'Σύμφωνα με τον νόμο 4679/2020, εμπορικό σήμα μπορεί να αποτελείται από λέξεις, ονόματα, σχέδια, γράμματα, αριθμούς, χρώματα, σχήμα προϊόντος ή συσκευασίας, ή ήχους, εφόσον μπορούν να διακρίνουν τα προϊόντα ή τις υπηρεσίες μιας επιχείρησης από εκείνα άλλων.' },
  { question: 'Προστατεύομαι για πάντα; Σε ποιες περιοχές;', answer: 'Η προστασία διαρκεί 10 έτη από την ημερομηνία κατάθεσης, με δυνατότητα ανανέωσης επ\' αόριστον. Εθνικό σήμα (Ελλάδα), σήμα ΕΕ (όλα τα κράτη-μέλη) ή διεθνής καταχώριση.' },
  { question: 'Γιατί χρειάζομαι ειδικό πριν την καταχώριση;', answer: 'Η καταχώριση σήματος χωρίς προηγούμενη νομική μελέτη μπορεί να αποτελέσει "παγίδα πρώτης κατηγορίας". Τρίτοι μπορούν να αμφισβητήσουν το σήμα με αιτήσεις ακύρωσης, αγωγές ή ποινικές διώξεις.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({ "@type": "Question", "name": item.question, "acceptedAnswer": { "@type": "Answer", "text": item.answer } })),
};

const clients = [
  { name: 'Arrena', logo: '/images/client-arrena.jpg' },
  { name: 'Jackaroo', logo: '/images/client-jackaroo.jpg' },
  { name: 'Nerapigon Grammou', logo: '/images/client-nerapigon.jpg' },
  { name: 'Chord', logo: '/images/client-chord.jpg' },
  { name: 'Simon', logo: '/images/client-simon.jpg' },
  { name: 'Lunch', logo: '/images/client-lunch.jpg' },
  { name: 'Brand', logo: '/images/client-brand.jpg' },
  { name: 'Papanikolaou', logo: '/images/client-papanikolaou.jpg' },
  { name: 'LB', logo: '/images/client-lb.jpg' },
];
---

<BaseLayout title="Κατοχύρωση Εμπορικού Σήματος" description="Κατοχύρωση εμπορικού σήματος - Δικηγόρος εμπορικών σημάτων | The Trademark Hoop">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- NEWS PORTAL: Featured + Feed + Sidebar -->
  <section class="news-section">
    <div class="container">
      <!-- Featured Post Banner -->
      {featuredPost && (
        <a href={`/blog/${featuredPost.slug}`} class="featured-post">
          {featuredPost.image && <img src={featuredPost.image} alt={featuredPost.title} class="featured-img" />}
          <div class="featured-overlay">
            <span class="featured-badge">Πρόσφατο</span>
            <h2>{featuredPost.title}</h2>
            <p>{excerpt(featuredPost.content, 200)}</p>
            <span class="featured-meta">{featuredPost.date} &bull; {featuredPost.author}</span>
          </div>
        </a>
      )}

      <div class="news-grid">
        <!-- Main Feed -->
        <div class="news-feed">
          <h2 class="feed-title">Τελευταία Άρθρα</h2>
          {feedPosts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="feed-item">
              <div class="feed-item-body">
                <span class="feed-date">{post.date}</span>
                <h3>{post.title}</h3>
                <p class="feed-excerpt">{excerpt(post.content)}</p>
                <span class="feed-author">{post.author}</span>
              </div>
              {post.image && (
                <div class="feed-item-thumb">
                  <img src={post.image} alt={post.title} loading="lazy" />
                </div>
              )}
            </a>
          ))}
          <div style="margin-top: 24px;">
            <a href="/blog/" class="btn-outline">Όλα τα άρθρα</a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="news-sidebar">
          <!-- CTA Widget -->
          <!-- E-Learning Banner -->
          <div class="sidebar-widget sidebar-elearning">
            <span class="sidebar-elearning-badge">E-Learning Course</span>
            <h4>Κατοχύρωση εμπορικού σήματος και αποτελεσματική προστασία του</h4>
            <p>από τη Νομική Βιβλιοθήκη</p>
            <a href="https://www.nb.org" target="_blank" rel="noopener" class="sidebar-elearning-btn">Μάθε περισσότερα</a>
          </div>

          <!-- Guest Blogging -->
          <div class="sidebar-widget sidebar-cta">
            <h4>Guest Blogging</h4>
            <p>Γράψε για εμάς! Δημοσίευσε το άρθρο σου στο Trademark Hoop.</p>
            <a href="/p/blog-page_8.html" class="sidebar-btn">Συνεργασίες</a>
          </div>

          <!-- Tags Cloud -->
          <div class="sidebar-widget">
            <h4>Tags</h4>
            <div class="sidebar-tags">
              {tags.map((tag: any) => (
                <a href={`/tag/${encodeURIComponent(tag.name)}`} class="sidebar-tag">{tag.name}</a>
              ))}
            </div>
          </div>

        </aside>
      </div>

    </div>
  </section>

  <!-- Contact -->
  <section class="section-contact" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Επικοινωνήστε μαζί μας</h2>
          <p class="contact-desc">Συμπληρώστε τη φόρμα ή επικοινωνήστε απευθείας μαζί μας.</p>
          <div class="contact-details">
            <div class="contact-detail"><strong>Διεύθυνση</strong><span>Λυκαβηττού 2, Κολωνάκι</span></div>
            <div class="contact-detail"><strong>Τηλέφωνο</strong><span>213 046 4985</span></div>
            <div class="contact-detail"><strong>Κινητό</strong><span>693 27 87 671</span></div>
            <div class="contact-detail"><strong>Email</strong><a href="mailto:info@thetrademarkhoop.com">info@thetrademarkhoop.com</a></div>
          </div>
        </div>
        <form class="contact-form-home" action="https://formsubmit.co/info@thetrademarkhoop.com" method="POST">
          <input type="hidden" name="_captcha" value="true" />
          <input type="hidden" name="_subject" value="Νέο μήνυμα - thetrademarkhoop.com" />
          <input type="hidden" name="_next" value="https://www.thetrademarkhoop.com/" />
          <input type="text" name="_honey" style="display:none" />
          <input type="text" name="name" placeholder="Όνομα" required />
          <input type="email" name="email" placeholder="Email" required />
          <input type="tel" name="phone" placeholder="Τηλέφωνο (προαιρετικό)" />
          <textarea name="message" placeholder="Μήνυμα" required></textarea>
          <label class="form-consent">
            <input type="checkbox" required />
            <span>Αποδέχομαι τους <a href="/p/trademark-hoop_26.html" target="_blank">Όρους Χρήσης</a> και την <a href="/p/trademark-hoop_26.html" target="_blank">Πολιτική Απορρήτου</a>.</span>
          </label>
          <button type="submit">Αποστολή</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
