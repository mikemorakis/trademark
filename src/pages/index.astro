---
import BaseLayout from '../layouts/BaseLayout.astro';
import { env } from "cloudflare:workers";

const db = env.DB;
let allPosts: any[] = [];
let tags: any[] = [];
let navCategories: any[] = [];

if (db) {
  const result = await db.prepare('SELECT id, title, slug, date, author, image, content, category_id FROM posts WHERE published = 1 ORDER BY date DESC').all();
  allPosts = result.results || [];
  const tagResult = await db.prepare('SELECT t.id, t.name, COUNT(pt.post_id) as count FROM tags t LEFT JOIN post_tags pt ON t.id = pt.tag_id GROUP BY t.id ORDER BY count DESC LIMIT 20').all();
  tags = tagResult.results || [];
  const catResult = await db.prepare(`
    SELECT c.id, c.name, c.slug, COUNT(p.id) as post_count
    FROM categories c JOIN posts p ON p.category_id = c.id AND p.published = 1
    GROUP BY c.id ORDER BY c.name
  `).all();
  navCategories = catResult.results || [];
}

const featuredPost = allPosts[0] || null;
const hotPosts = allPosts.slice(1, 6);
const feedPosts = allPosts.slice(6, 16);

const excerpt = (content: string, len = 160) => {
  if (!content) return '';
  return content.replace(/<[^>]*>?/g, '').replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&').replace(/\s+/g, ' ').trim().substring(0, len) + (content.length > len ? '...' : '');
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Με συμφέρει η κατοχύρωση εμπορικού σήματος;", "acceptedAnswer": { "@type": "Answer", "text": "Η κατοχύρωση εμπορικού σήματος αποτελεί μια ιδιαίτερα συμφέρουσα επιλογή για κάθε επιχείρηση." } },
  ],
};
---

<BaseLayout title="The Trademark Hoop" description="Κατοχύρωση εμπορικού σήματος - Δικηγόρος εμπορικών σημάτων | The Trademark Hoop">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- HERO: Featured + Hot This Week -->
  <section class="mag-hero">
    <div class="container">
      <div class="mag-hero-grid">
        <!-- Featured (Left) -->
        {featuredPost && (
          <a href={`/blog/${featuredPost.slug}`} class="mag-featured">
            <div class="mag-featured-img">
              {featuredPost.image ? <img src={featuredPost.image} alt={featuredPost.title} /> : <div class="mag-featured-placeholder"></div>}
            </div>
            <div class="mag-featured-body">
              <span class="mag-category-badge">Πρόσφατο</span>
              <h2>{featuredPost.title}</h2>
              <p>{excerpt(featuredPost.content, 180)}</p>
              <span class="mag-meta">{featuredPost.date} &bull; {featuredPost.author}</span>
            </div>
          </a>
        )}

        <!-- Hot This Week (Right) -->
        <div class="mag-hot">
          <h3 class="mag-hot-title">Δημοφιλή Νέα</h3>
          <div class="mag-hot-list">
            {hotPosts.map((post: any, i: number) => (
              <a href={`/blog/${post.slug}`} class="mag-hot-item">
                <div class="mag-hot-body">
                  <span class="mag-hot-cat">Trademark</span>
                  <h4>{post.title}</h4>
                </div>
                <span class="mag-hot-num">{i + 1}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TOPICS: Feed + Sidebar -->
  <section class="mag-topics">
    <div class="container">
      <div class="news-grid">
        <!-- Feed -->
        <div class="news-feed">
          <h2 class="feed-title">Τελευταία Άρθρα</h2>
          {feedPosts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="feed-item">
              <div class="feed-item-body">
                <span class="feed-date">{post.date}</span>
                <h3>{post.title}</h3>
                <p class="feed-excerpt">{excerpt(post.content)}</p>
                <span class="feed-author">{post.author}</span>
              </div>
              {post.image && (
                <div class="feed-item-thumb">
                  <img src={post.image} alt={post.title} loading="lazy" />
                </div>
              )}
            </a>
          ))}
        </div>

        <!-- Sidebar -->
        <aside class="news-sidebar">
          <div class="sidebar-widget sidebar-elearning">
            <span class="sidebar-elearning-badge">E-Learning Course</span>
            <h4>Κατοχύρωση εμπορικού σήματος και αποτελεσματική προστασία του</h4>
            <p>από τη Νομική Βιβλιοθήκη</p>
            <a href="https://www.nb.org" target="_blank" rel="noopener" class="sidebar-elearning-btn">Μάθε περισσότερα</a>
          </div>

          <div class="sidebar-widget sidebar-cta">
            <h4>Guest Blogging</h4>
            <p>Γράψε για εμάς! Δημοσίευσε το άρθρο σου στο Trademark Hoop.</p>
            <a href="/p/blog-page_8.html" class="sidebar-btn">Συνεργασίες</a>
          </div>

          <div class="sidebar-widget">
            <h4>Tags</h4>
            <div class="sidebar-tags">
              {tags.map((tag: any) => (
                <a href={`/tag/${encodeURIComponent(tag.name)}`} class="sidebar-tag">{tag.name}</a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section-contact" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Επικοινωνήστε μαζί μας</h2>
          <p class="contact-desc">Συμπληρώστε τη φόρμα ή επικοινωνήστε απευθείας μαζί μας.</p>
          <div class="contact-details">
            <div class="contact-detail"><strong>Διεύθυνση</strong><span>Λυκαβηττού 2, Κολωνάκι</span></div>
            <div class="contact-detail"><strong>Τηλέφωνο</strong><span>213 046 4985</span></div>
            <div class="contact-detail"><strong>Κινητό</strong><span>693 27 87 671</span></div>
            <div class="contact-detail"><strong>Email</strong><a href="mailto:info@thetrademarkhoop.com">info@thetrademarkhoop.com</a></div>
          </div>
        </div>
        <form class="contact-form-home" action="https://formsubmit.co/info@thetrademarkhoop.com" method="POST">
          <input type="hidden" name="_captcha" value="true" />
          <input type="hidden" name="_subject" value="Νέο μήνυμα - thetrademarkhoop.com" />
          <input type="hidden" name="_next" value="https://www.thetrademarkhoop.com/" />
          <input type="text" name="_honey" style="display:none" />
          <input type="text" name="name" placeholder="Όνομα" required />
          <input type="email" name="email" placeholder="Email" required />
          <input type="tel" name="phone" placeholder="Τηλέφωνο (προαιρετικό)" />
          <textarea name="message" placeholder="Μήνυμα" required></textarea>
          <label class="form-consent">
            <input type="checkbox" required />
            <span>Αποδέχομαι τους <a href="/p/trademark-hoop_26.html" target="_blank">Όρους Χρήσης</a> και την <a href="/p/trademark-hoop_26.html" target="_blank">Πολιτική Απορρήτου</a>.</span>
          </label>
          <button type="submit">Αποστολή</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
