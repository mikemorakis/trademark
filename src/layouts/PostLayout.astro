---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  date: string;
  author?: string;
  tags?: string[];
  description?: string;
}

const { title, date, author = 'Giannis Psarakis', tags = [], description } = Astro.props;
---

<BaseLayout title={title} description={description || title}>
  <div class="main-content">
    <div class="content-area">
      <article class="single-post">
        <h1>{title}</h1>
        <div class="post-meta">
          <span>{date}</span>
          <span>{author}</span>
        </div>
        <div class="post-content">
          <slot />
        </div>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => (
              <a href={`/search?q=${tag}`}>{tag}</a>
            ))}
          </div>
        )}
      </article>
    </div>

    <Sidebar />
  </div>
</BaseLayout>
