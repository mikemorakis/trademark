---
import { env } from "cloudflare:workers";

interface Props {
  title: string;
  description?: string;
  transparentHeader?: boolean;
}

const { title, description = 'Hoop it. Don\'t get hooped. Legally. | Advice. Registration. Litigation.', transparentHeader = false } = Astro.props;

let navCategories: any[] = [];
try {
  const db = env.DB;
  if (db) {
    const result = await db.prepare(`
      SELECT c.name, c.slug, COUNT(p.id) as post_count
      FROM categories c
      JOIN posts p ON p.category_id = c.id AND p.published = 1
      GROUP BY c.id
      ORDER BY c.name
    `).all();
    navCategories = result.results || [];
  }
} catch(e) {}
---

<html lang="el">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://images.pexels.com https://*.pexels.com; font-src 'self'; connect-src 'self' https://formsubmit.co https://api.pexels.com; form-action 'self' https://formsubmit.co" />
  <meta name="description" content={description} />
  <title>{title} | The Trademark Hoop</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/styles.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="/styles.css" /></noscript>
  <style is:inline>:root{--navy:#0f2d4a;--orange:#ff6b4a;--white:#fff;--text-dark:#1f2937;--text-gray:#4b5563;--gray:#d1d5db;--light-gray:#f3f4f6}*{box-sizing:border-box;margin:0;padding:0}body{font-family:Verdana,sans-serif;font-weight:400;color:#1f2937;background:linear-gradient(180deg,#001a33 0%,#002141 15%,#00294f 50%,#002141 85%,#001a33 100%);background-attachment:fixed;font-size:15px;line-height:1.75}main{background:#fff;max-width:1140px;margin:0 auto}.site-header{background:transparent;padding:16px 0;position:relative;z-index:1000}.header-inner{display:flex;align-items:center;justify-content:space-between;max-width:1140px;margin:0 auto}.site-logo img{height:52px;width:auto}.main-nav{display:flex;align-items:center;gap:5px}.main-nav a{font-family:Verdana,sans-serif;font-size:.65rem;font-weight:700;color:rgba(255,255,255,.8);padding:8px 10px;text-transform:uppercase;letter-spacing:.8px;white-space:nowrap;text-decoration:none}.hamburger{display:none}@media(max-width:1100px){.hamburger{display:flex;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:5px}.hamburger span{display:block;width:25px;height:3px;background:#fff}.main-nav{display:none}}</style>
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="canonical" href={Astro.url.href} />
  <slot name="head" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LegalService",
    "name": "The Trademark Hoop",
    "description": "Specialized trademark law firm - Psarakis | Kephalas Law Firm",
    "url": "https://www.thetrademarkhoop.com",
    "telephone": "+302130464985",
    "email": "info@thetrademarkhoop.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Lykavittou 2, Kolonaki",
      "addressLocality": "Athens",
      "addressCountry": "GR"
    }
  })} />
</head>
<body>
  <!-- Header -->
  <header class={`site-header${transparentHeader ? ' transparent' : ''}`} id="siteHeader">
    <div class="header-inner">
      <a href="/" class="site-logo">
        <img src="/trademarkhoop-logo.png" alt="The Trademark Hoop" width="231" height="55" />
      </a>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <nav class="main-nav" id="mainNav">
        <div class="nav-mobile-header">
          <img src="/trademarkhoop-logo.png" alt="The Trademark Hoop" class="nav-mobile-logo" />
          <button class="nav-close" id="navClose" aria-label="Close menu">&times;</button>
        </div>
        <div class="nav-links">
          {navCategories.map((cat: any) => (
            <a href={`/category/${cat.slug}`}>{cat.name}</a>
          ))}
          <a href="/p/blog-page_8.html" class="nav-btn-cta">Συνεργάσου μαζί μας</a>
        </div>
        <hr class="nav-mobile-hr" />
        <div class="nav-mobile-ctas">
          <a href="/p/blog-page_8.html" class="nav-cta-primary">Συνεργάσου μαζί μας</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <!-- Top Bar -->
    <div class="footer-top">
      <div class="container">
        <div class="footer-top-inner">
          <div class="footer-brand">
            <img src="/trademarkhoop-logo.png" alt="The Trademark Hoop" class="footer-logo" />
            <p>Λυκαβηττού 2, Κολωνάκι, Αθήνα</p>
          </div>
          <div class="footer-phones">
            <a href="tel:+302130464985" class="phone-btn">213 046 4985</a>
            <a href="tel:+306932787671" class="phone-btn">693 27 87 671</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Footer -->
    <div class="footer-main">
      <div class="container">
        <!-- Practice Info -->
        <div class="footer-practice">
          <h3>Trademark Law Practice - Athens</h3>
          <p>Εξειδικευμένη νομική εκπροσώπηση σε θέματα εμπορικών σημάτων με έμφαση σε στρατηγική, διακριτικότητα και άμεση ανταπόκριση σε κρίσιμες υποθέσεις.</p>
          <div class="footer-badges">
            <span class="footer-badge">Εξειδίκευση σε Εμπορικά Σήματα</span>
            <span class="footer-badge">Ελλάδα & ΕΕ</span>
            <span class="footer-badge">EUIPO & OBI</span>
            <span class="footer-badge">Εμπιστευτικότητα</span>
          </div>
        </div>

        <!-- Links Grid -->
        <div class="footer-grid">
          <div class="footer-section">
            <h3>Υπηρεσίες</h3>
            <a href="/p/we-do.html">Κατοχύρωση Σήματος</a>
            <a href="/p/we-do.html">Ένσταση (Opposition)</a>
            <a href="/p/we-do.html">Ανάκληση Σήματος</a>
            <a href="/p/we-do.html">Νομικός Προέλεγχος</a>
            <a href="/p/we-do.html">Δικαστική Προστασία</a>
            <a href="/p/we-do.html">Γνωμοδοτήσεις</a>
          </div>
          <div class="footer-section">
            <h3>Πληροφορίες</h3>
            <a href="/p/trademark-hoop_26.html">The Hoop</a>
            <a href="/p/1.html">TM Stories+</a>
            <a href="/p/trademark-hoop.html">Συχνές Ερωτήσεις</a>
            <a href="/p/who.html">Σχετικά με εμάς</a>
            <a href="/p/blog-page_8.html">Επικοινωνία</a>
          </div>
          <div class="footer-section">
            <h3>Επικοινωνία</h3>
            <p>Λυκαβηττού 2, Κολωνάκι</p>
            <p>Αθήνα, Ελλάδα</p>
            <p>T: <a href="tel:+302130464985">213 046 4985</a></p>
            <p>M: <a href="tel:+306932787671">693 27 87 671</a></p>
            <p><a href="mailto:info@thetrademarkhoop.com">info@thetrademarkhoop.com</a></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Legal Policies -->
    <div class="footer-legal">
      <div class="container">
        <h3>Νομικοί Όροι & Πολιτικές</h3>
        <div class="footer-policies">
          <a href="/p/trademark-hoop_26.html">Όροι Χρήσης</a>
          <a href="/p/trademark-hoop_26.html">Terms & Conditions</a>
          <a href="/p/trademark-hoop_26.html">Privacy Policy</a>
          <a href="/p/trademark-hoop_26.html">GDPR Policy</a>
          <a href="/p/trademark-hoop_26.html">Cookies Policy</a>
          <a href="/p/trademark-hoop_26.html">Legal Disclaimer</a>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="footer-disclaimer">
      <div class="container">
        <p>Το περιεχόμενο της ιστοσελίδας έχει ενημερωτικό χαρακτήρα και δεν συνιστά εξατομικευμένη νομική συμβουλή. Η νομική αξιολόγηση παρέχεται μόνο κατόπιν άμεσης επικοινωνίας και πλήρους εξέτασης των πραγματικών περιστατικών.</p>
        <p>Για θέματα προστασίας προσωπικών δεδομένων, δικαιώματα υποκειμένων και διαχείριση συγκατάθεσης cookies, μπορείτε να επικοινωνείτε στο <a href="tel:+302130464985">213 046 4985</a>.</p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="footer-bottom">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} The Trademark Hoop | Ψαράκης & Κεφαλάς Δικηγορική Εταιρεία. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Cookie Consent Bar -->
  <div class="cookie-bar" id="cookieBar">
    <div class="cookie-bar-inner">
      <div class="cookie-bar-content">
        <div class="cookie-bar-header">
          <img src="/trademarkhoop-logo.png" alt="The Trademark Hoop" class="cookie-logo" />
        </div>
        <p>Χρησιμοποιούμε cookies για τη βελτίωση της εμπειρίας σας, την ανάλυση επισκεψιμότητας και την προβολή εξατομικευμένου περιεχομένου. Μπορείτε να διαχειριστείτε τις προτιμήσεις σας παρακάτω. Για περισσότερες πληροφορίες, δείτε την <a href="/p/trademark-hoop_26.html">Πολιτική Cookies</a> και την <a href="/p/trademark-hoop_26.html">Πολιτική Απορρήτου</a>.</p>
        <div class="cookie-options" id="cookieOptions" style="display:none;">
          <label class="cookie-toggle">
            <input type="checkbox" checked disabled />
            <span class="cookie-label">
              <strong>Απαραίτητα</strong>
              <small>Απαιτούνται για τη βασική λειτουργία του ιστότοπου. Δεν μπορούν να απενεργοποιηθούν.</small>
            </span>
          </label>
          <label class="cookie-toggle">
            <input type="checkbox" id="cookieAnalytics" checked />
            <span class="cookie-label">
              <strong>Αναλυτικά</strong>
              <small>Μας βοηθούν να κατανοήσουμε πώς χρησιμοποιείτε τον ιστότοπο (Google Analytics).</small>
            </span>
          </label>
          <label class="cookie-toggle">
            <input type="checkbox" id="cookieMarketing" />
            <span class="cookie-label">
              <strong>Μάρκετινγκ</strong>
              <small>Χρησιμοποιούνται για εξατομικευμένες διαφημίσεις και remarketing.</small>
            </span>
          </label>
          <label class="cookie-toggle">
            <input type="checkbox" id="cookieFunctional" checked />
            <span class="cookie-label">
              <strong>Λειτουργικά</strong>
              <small>Βελτιώνουν τη λειτουργικότητα, όπως ενσωματωμένα βίντεο και χάρτες.</small>
            </span>
          </label>
        </div>
      </div>
      <div class="cookie-bar-actions">
        <button class="cookie-btn-settings" id="cookieToggleOptions">Ρυθμίσεις</button>
        <button class="cookie-btn-reject" id="cookieReject">Απόρριψη Όλων</button>
        <button class="cookie-btn-accept" id="cookieAccept">Αποδοχή Όλων</button>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('hamburger')?.addEventListener('click', () => {
      document.getElementById('mainNav')?.classList.add('open');
    });
    document.getElementById('navClose')?.addEventListener('click', () => {
      document.getElementById('mainNav')?.classList.remove('open');
    });

    const header = document.getElementById('siteHeader');
    if (header?.classList.contains('transparent')) {
      window.addEventListener('scroll', () => {
        header.classList.toggle('scrolled', window.scrollY > 50);
      });
    }

    // Cookie Consent
    (function() {
      const bar = document.getElementById('cookieBar');
      const opts = document.getElementById('cookieOptions');
      if (localStorage.getItem('cookieConsent')) { bar.style.display = 'none'; return; }
      bar.style.display = 'flex';

      document.getElementById('cookieToggleOptions')?.addEventListener('click', () => {
        opts.style.display = opts.style.display === 'none' ? 'block' : 'none';
      });

      document.getElementById('cookieAccept')?.addEventListener('click', () => {
        localStorage.setItem('cookieConsent', JSON.stringify({
          necessary: true,
          analytics: true,
          marketing: true,
          functional: true,
          date: new Date().toISOString()
        }));
        bar.style.display = 'none';
      });

      document.getElementById('cookieReject')?.addEventListener('click', () => {
        localStorage.setItem('cookieConsent', JSON.stringify({
          necessary: true,
          analytics: false,
          marketing: false,
          functional: false,
          date: new Date().toISOString()
        }));
        bar.style.display = 'none';
      });
    })();
  </script>
</body>
</html>

